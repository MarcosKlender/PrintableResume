---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<
  HTMLAttributes<"svg">,
  | "fill"
  | "stroke"
  | "viewBox"
  | "stroke-width"
  | "stroke-linecap"
  | "stroke-linejoin"
>;
---

<svg
  {...Astro.props}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="2"
  viewBox="0 0 24 24"
  ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
    d="M15 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
    d="M6 3m0 3a3 3 0 0 1 3 -3h6a3 3 0 0 1 3 3v0a3 3 0 0 1 -3 3h-6a3 3 0 0 1 -3 -3z"
  ></path><path d="M9 9a3 3 0 0 0 0 6h3m-3 0a3 3 0 1 0 3 3v-15"></path></svg
>
