---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<
  HTMLAttributes<"svg">,
  | "fill"
  | "stroke"
  | "viewBox"
  | "stroke-width"
  | "stroke-linecap"
  | "stroke-linejoin"
>;
---

<svg
  {...Astro.props}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="2"
  viewBox="0 0 24 24"
  ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
    d="M3 11.5l4.5 4.5h9l-9 -9z"></path><path
    d="M16.5 16l4.5 -4.5l-4.5 -4.5l-4.5 4.5"></path></svg
>
