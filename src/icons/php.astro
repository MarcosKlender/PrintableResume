---
import type { HTMLAttributes } from "astro/types";

type Props = Omit<
  HTMLAttributes<"svg">,
  | "fill"
  | "stroke"
  | "viewBox"
  | "stroke-width"
  | "stroke-linecap"
  | "stroke-linejoin"
>;
---

<svg
  {...Astro.props}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="2"
  viewBox="0 0 24 24"
  ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
    d="M12 12m-10 0a10 9 0 1 0 20 0a10 9 0 1 0 -20 0"></path><path
    d="M5.5 15l.395 -1.974l.605 -3.026h1.32a1 1 0 0 1 .986 1.164l-.167 1a1 1 0 0 1 -.986 .836h-1.653"
  ></path><path
    d="M15.5 15l.395 -1.974l.605 -3.026h1.32a1 1 0 0 1 .986 1.164l-.167 1a1 1 0 0 1 -.986 .836h-1.653"
  ></path><path d="M12 7.5l-1 5.5"></path><path d="M11.6 10h2.4l-.5 3"
  ></path></svg
>
